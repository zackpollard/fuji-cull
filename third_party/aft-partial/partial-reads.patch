+	void Session::GetPart(mtp::u32 id, const std::string &offset, const std::string &size, const LocalPath &dst)
+	{
+		mtp::u64 off = strtoull(offset.c_str(), nullptr, 10);
+		mtp::u32 sz  = (mtp::u32)strtoul(size.c_str(), nullptr, 10);
+		mtp::ByteArray data = _session->GetPartialObject(mtp::ObjectId(id), off, sz);
+		FILE *f = fopen(dst.c_str(), "wb");
+		if (!f)
+			throw std::runtime_error("cannot open " + std::string(dst.c_str()));
+		fwrite(data.data(), 1, data.size(), f);
+		fclose(f);
+	}
+
+	void Session::ServeParts()
+	{
+		// Persistent partial-read protocol for embedding applications:
+		// request  'R <id> <offset> <size>\n'
+		// response 'OK <n>\n' followed by n raw bytes, or 'ERR <msg>\n'.
+		// Marks the response start with a leading '\x01' so clients can skip
+		// any library chatter on stdout.
+		std::string line;
+		while (std::getline(std::cin, line))
+		{
+			if (line == "Q")
+				break;
+			unsigned long long id = 0, off = 0, sz = 0;
+			if (sscanf(line.c_str(), "R %llu %llu %llu", &id, &off, &sz) != 3)
+			{
+				printf("\x01ERR parse\n");
+				fflush(stdout);
+				continue;
+			}
+			try
+			{
+				mtp::ByteArray data = _session->GetPartialObject(mtp::ObjectId((mtp::u32)id), off, (mtp::u32)sz);
+				printf("\x01OK %zu\n", data.size());
+				fflush(stdout);
+				fwrite(data.data(), 1, data.size(), stdout);
+				fflush(stdout);
+			}
+			catch (const std::exception &ex)
+			{
+				printf("\x01ERR %s\n", ex.what());
+				fflush(stdout);
+			}
+		}
+	}
+
