+	DeviceDescriptor::DeviceDescriptor(int fd): _busId(-1), _path("<fd>"), _fd(fd)
+	{
+		debug("creating device descriptor from fd ", fd);
+		lseek(fd, 0, SEEK_SET);
+		ByteArray blob(4096);
+		ssize_t n = ::read(fd, blob.data(), blob.size());
+		if (n < 18 + 9)
+			throw std::runtime_error("cannot read usb descriptors from fd");
+		blob.resize(n);
+		_descriptor			= blob;
+		_vendor				= blob[8] | (blob[9] << 8);
+		_product			= blob[10] | (blob[11] << 8);
+		_deviceNumber		= -1;
+		_controlEp			= std::make_shared<Endpoint>(0, blob[7], EndpointDirection::Both, EndpointType::Control);
+		_configurationValue	= blob[18 + 5]; // first configuration descriptor
+	}
