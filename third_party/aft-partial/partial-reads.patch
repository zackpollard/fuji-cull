+	// InfoId prints handle, size and filename for one object. Size prefers
+	// the 64-bit ObjectSize property (GetObjectInfo caps at 4 GiB).
+	void Session::InfoId(mtp::ObjectId id)
+	{
+		using namespace mtp;
+		auto info = _session->GetObjectInfo(id);
+		u64 size = info.ObjectCompressedSize;
+		try
+		{ size = _session->GetObjectIntegerProperty(id, ObjectProperty::ObjectSize); }
+		catch (const std::exception &)
+		{ }
+		print(std::left, width(id.Id, 10), " ", size, " ", info.Filename);
+	}
