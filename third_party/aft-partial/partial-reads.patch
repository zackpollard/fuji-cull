+	DeviceDescriptor::DeviceDescriptor(int fd): _busId(-1), _path("<fd>"), _fd(fd)
+	{
+		debug("creating device descriptor from fd ", fd);
+		lseek(fd, 0, SEEK_SET);
+		ByteArray blob(4096);
+		ssize_t n = ::read(fd, blob.data(), blob.size());
+		if (n < 18 + 9)
+			throw std::runtime_error("cannot read usb descriptors from fd");
+		blob.resize(n);
+		_descriptor			= blob;
+		_vendor				= blob[8] | (blob[9] << 8);
+		_product			= blob[10] | (blob[11] << 8);
+		_deviceNumber		= -1;
+		_controlEp			= std::make_shared<Endpoint>(0, blob[7], EndpointDirection::Both, EndpointType::Control);
+		_configurationValue	= blob[18 + 5]; // first configuration descriptor
+
+		// no sysfs on this path: synthesize configurations/interfaces/endpoints
+		// from the raw descriptor set that usbfs returns after the device
+		// descriptor (Device::Open finds MTP by class 6 subclass 1)
+		int confIndex = -1, currentInterface = -1;
+		u8 klass = 0, subclass = 0;
+		std::vector<EndpointPtr> eps;
+		auto flushInterface = [&]() {
+			if (confIndex >= 0 && currentInterface >= 0)
+				AddInterface(confIndex, currentInterface,
+					std::make_shared<Interface>(currentInterface, klass, subclass, std::move(eps)));
+			eps.clear();
+			currentInterface = -1;
+		};
+		size_t off = 0;
+		while (off + 2 <= blob.size())
+		{
+			u8 dlen = blob[off], dtype = blob[off + 1];
+			if (dlen < 2 || off + dlen > blob.size())
+				break;
+			switch (dtype)
+			{
+			case 2: // configuration
+				flushInterface();
+				++confIndex;
+				break;
+			case 4: // interface, alt-setting 0 only
+				flushInterface();
+				if (blob[off + 3] == 0)
+				{
+					currentInterface = blob[off + 2];
+					klass = blob[off + 5];
+					subclass = blob[off + 6];
+				}
+				break;
+			case 5: // endpoint
+				if (currentInterface >= 0 && dlen >= 7)
+				{
+					u8 addr = blob[off + 2];
+					u8 attrs = blob[off + 3] & 3;
+					u16 mps = blob[off + 4] | (blob[off + 5] << 8);
+					eps.push_back(std::make_shared<Endpoint>(addr, mps,
+						(addr & 0x80) ? EndpointDirection::In : EndpointDirection::Out,
+						static_cast<EndpointType>(attrs)));
+				}
+				break;
+			}
+			off += dlen;
+		}
+		flushInterface();
+		debug("fd descriptor parse: ", GetConfigurationsCount(), " configuration(s)");
+	}
