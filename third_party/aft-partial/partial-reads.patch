+	// ListProps lists a folder with sizes using TWO bulk GetObjectPropList
+	// requests instead of one GetObjectInfo round-trip per file — the
+	// difference between ~90s and ~1s on a 19k-file card.
+	void Session::ListProps(mtp::ObjectId parent)
+	{
+		using namespace mtp;
+		if (!_session->GetObjectPropertyListSupported())
+			throw std::runtime_error("GetObjectPropList not supported by device");
+		std::map<mtp::ObjectId, u64> sizes;
+		{
+			ByteArray data = _session->GetObjectPropertyList(parent, ObjectFormat::Any, ObjectProperty::ObjectSize, 0, 1);
+			ObjectPropertyListParser<u64> parser;
+			parser.Parse(data, [&sizes](ObjectId objectId, ObjectProperty, u64 size)
+			{ sizes[objectId] = size; });
+		}
+		ByteArray data = _session->GetObjectPropertyList(parent, ObjectFormat::Any, ObjectProperty::ObjectFilename, 0, 1);
+		ObjectPropertyListParser<std::string> parser;
+		size_t parsed = 0;
+		parser.Parse(data, [&sizes, &parsed](ObjectId objectId, ObjectProperty, const std::string &name)
+		{
+			++parsed;
+			auto it = sizes.find(objectId);
+			print(std::left, width(objectId, 10), " ", it != sizes.end()? it->second: 0, " ", name);
+		});
+		// a device can "support" the opcode yet answer with a dataset the
+		// parser cannot read — fail loudly so callers fall back visibly
+		// instead of listing folders as silently empty
+		if (parsed == 0 && data.size() > 12)
+			throw std::runtime_error("GetObjectPropList: " + std::to_string(data.size()) + " bytes but no parseable entries");
+	}
+
+	// ListPropsAll dumps every object on the device in three card-wide
+	// GetObjectPropList requests (handle=0xFFFFFFFF "all objects", depth 0 —
+	// the only shape the X-H2S honors: depth queries return
+	// UnsupportedSpecByDepth, format filters SpecificationByFormatUnsupported).
+	// 19,702 objects arrived in a single 689 KB response in field testing.
+	void Session::ListPropsAll()
+	{
+		using namespace mtp;
+		if (!_session->GetObjectPropertyListSupported())
+			throw std::runtime_error("GetObjectPropList not supported by device");
+		const ObjectId all(0xffffffffu);
+		std::map<mtp::ObjectId, u64> sizes;
+		{
+			ByteArray data = _session->GetObjectPropertyList(all, ObjectFormat::Any, ObjectProperty::ObjectSize, 0, 0);
+			ObjectPropertyListParser<u64> parser;
+			parser.Parse(data, [&sizes](ObjectId objectId, ObjectProperty, u64 size)
+			{ sizes[objectId] = size; });
+		}
+		std::map<mtp::ObjectId, u64> parents;
+		{
+			ByteArray data = _session->GetObjectPropertyList(all, ObjectFormat::Any, ObjectProperty::ParentObject, 0, 0);
+			ObjectPropertyListParser<u64> parser;
+			parser.Parse(data, [&parents](ObjectId objectId, ObjectProperty, u64 parent)
+			{ parents[objectId] = parent; });
+		}
+		ByteArray data = _session->GetObjectPropertyList(all, ObjectFormat::Any, ObjectProperty::ObjectFilename, 0, 0);
+		ObjectPropertyListParser<std::string> parser;
+		size_t parsed = 0;
+		parser.Parse(data, [&sizes, &parents, &parsed](ObjectId objectId, ObjectProperty, const std::string &name)
+		{
+			++parsed;
+			auto sz = sizes.find(objectId);
+			auto pr = parents.find(objectId);
+			print(std::left,
+				width(objectId, 10), " ",
+				sz != sizes.end()? sz->second: 0, " ",
+				pr != parents.end()? pr->second: 0, " ",
+				name);
+		});
+		if (parsed == 0 && data.size() > 12)
+			throw std::runtime_error("GetObjectPropList(all): " + std::to_string(data.size()) + " bytes but no parseable entries");
+	}
+
+	// ListPropsProbe tries several GetObjectPropList parameter shapes —
+	// devices are picky about which combinations they honor (the X-H2S
+	// answers the folder/depth-1 shape with an empty dataset), and this
+	// reports what each shape yields so the right one can be adopted.
+	void Session::ListPropsProbe(mtp::ObjectId parent)
+	{
+		using namespace mtp;
+		auto probe = [this](const std::string &name, ObjectId handle, ObjectFormat fmt, ObjectProperty prop, u32 group, u32 depth)
+		{
+			try
+			{
+				ByteArray data = _session->GetObjectPropertyList(handle, fmt, prop, group, depth);
+				size_t parsed = 0;
+				try
+				{
+					ObjectPropertyListParser<std::string> parser;
+					parser.Parse(data, [&parsed](ObjectId, ObjectProperty, const std::string &) { ++parsed; });
+					print("probe ", name, ": ", data.size(), " bytes, ", parsed, " entries");
+				}
+				catch (const std::exception &ex)
+				{ print("probe ", name, ": ", data.size(), " bytes, parse error after ", parsed, ": ", ex.what()); }
+			}
+			catch (const std::exception &ex)
+			{ print("probe ", name, ": request error: ", ex.what()); }
+		};
+		probe("folder/fname/d1   ", parent, ObjectFormat::Any, ObjectProperty::ObjectFilename, 0, 1);
+		probe("folder/allprops/d1", parent, ObjectFormat::Any, ObjectProperty::All, 0, 1);
+		probe("h0/fname/dAll     ", ObjectId(0), ObjectFormat::Any, ObjectProperty::ObjectFilename, 0, 0xffffffffu);
+		probe("hAll/fname/d0     ", ObjectId(0xffffffffu), ObjectFormat::Any, ObjectProperty::ObjectFilename, 0, 0);
+		probe("folder/fname/jpeg/d1", parent, ObjectFormat::ExifJpeg, ObjectProperty::ObjectFilename, 0, 1);
+	}
+
